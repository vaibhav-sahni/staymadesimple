--UPDATE BOOKING STATUS
UPDATE booking b
SET 
    booking_status = $2,
    start_date = $3,
    end_date = $4
FROM customers c
WHERE b.booking_id = $1
  AND b.customer_id = c.customer_id
  AND c.user_id = $5
