--LIST ALL BOOKINGS of a specific customer
SELECT b.booking_id, b.customer_id, c.full_name as customer_name, b.room_id, b.start_date, b.end_date,
b.booking_status
FROM booking as b
JOIN customer as c on b.customer_id = c.customer_id
JOIN room as r on b.room_id = r.room_id
WHERE c.user_id = 'INT user_id'
ORDER BY b.booking_id;
--UPDATE BOOKING STATUS
UPDATE booking
SET booking_status = 'Active'
start_date = 'YYYY-MM-DD', end_date ='yyyy-mm-dd'
WHERE booking_id='INT booking_id' 
AND customer_id = (SELECT customer_id FROM customer WHERE user_id = 'INT user_id');
--DELETE BOOKING
UPDATE booking
SET booking_status = 'CANCELLED'
WHERE booking_id='INT booking_id' 
AND customer_id = (SELECT customer_id FROM customer WHERE user_id = 'INT user_id');
