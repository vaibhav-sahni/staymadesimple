--LIST ALL BOOKINGS IN PROPERTIES ALONG WITH CLIENT AND OWNER ID
SELECT 
    b.booking_id,
    c.full_name AS customer_name,
    r.room_number,
    b.start_date,
    b.end_date,
    b.booking_status,
    o.owner_id,
    oc.full_name AS owner_name
FROM booking b
JOIN room r ON b.room_id = r.room_id
JOIN property p ON r.property_id = p.property_id
JOIN owner o ON p.owner_id = o.owner_id
JOIN customers oc ON o.customer_id = oc.customer_id
JOIN customers c ON b.customer_id = c.customer_id
ORDER BY o.owner_id, b.start_date;

--LIST PROPERTIES WITH NO AVAILABLE ROOMS
SELECT p.property_id, p.property_description, p.city, p.average_rating
FROM property p
WHERE NOT EXISTS (
    SELECT 1
    FROM room r
    WHERE r.property_id = p.property_id
      AND r.is_booked = FALSE
);

-- LIST PROPERTIES WITH AVAILABLE ROOMS
SELECT p.property_id, p.property_description, p.city, p.average_rating
FROM property p
WHERE EXISTS (
    SELECT 1
    FROM room r
    WHERE r.property_id = p.property_id
      AND r.is_active = TRUE
      AND r.is_booked = FALSE
);
