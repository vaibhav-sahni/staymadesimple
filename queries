--LIST ALL PROPERTIES (FILTER BY CITY)
SELECT property_id, property_description, city, property_type
FROM property
WHERE city = 'city'
LIMIT 50;

--LIST PROPERTY (FILTER BY PRICE)
SELECT DISTINCT p.property_id, p.city, p.average_rating FROM property p
WHERE EXISTS (
  SELECT 1 FROM room r WHERE r.property_id = p.property_id AND r.is_active = TRUE
  AND r.rent_per_month >= 5000 AND r.rent_per_month <= 15000
) LIMIT 50;

